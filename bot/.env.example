# Token del bot de Telegram (obtener de @BotFather)
BOT_TOKEN=

# ID del Google Sheet (se encuentra en la URL: docs.google.com/spreadsheets/d/{ESTE_ID}/edit)
GOOGLE_SHEET_ID=

# Credenciales del Service Account de Google (del JSON descargado)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Telegram user IDs (enviar mensaje a @userinfobot para obtenerlo)
MOISES_TELEGRAM_ID=
ORIANA_TELEGRAM_ID=

# Ingresos mensuales (opcionales, para /cotizacion y recordatorio)
# Si no se configuran, el recordatorio mensual no se envia
MOISES_SALARY_USD=
MOISES_SALARY_ARS=
ORIANA_SALARY_USD=
ORIANA_SALARY_ARS=

# Día de cierre de tarjetas de crédito (1-28, para calcular primera cuota)
# Si no se configuran, la primera cuota se asigna siempre al mes siguiente
CIERRE_GALICIA=
CIERRE_BBVA=

# OpenAI API Key (opcional, para transcripción de audio y lectura de recibos)
OPENAI_API_KEY=
